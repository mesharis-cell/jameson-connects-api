PORT=3000
# Get API key from https://resend.com - required for sending email with recording attachment
RESEND_API_KEY=re_your_resend_api_key_here
# Must be a verified sender in Resend (e.g. onboarding@resend.dev for testing, or your domain)
FROM_EMAIL=onboarding@resend.dev
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=jam0036-jameson-recording

